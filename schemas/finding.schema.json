{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://inzohra.ai/schemas/finding.schema.json",
  "title": "Finding",
  "description": "A single reviewer finding emitted by a rule or LLM reasoning pass.",
  "type": "object",
  "required": [
    "finding_id", "project_id", "submittal_id", "review_round",
    "discipline", "severity", "requires_licensed_review",
    "sheet_reference", "evidence", "citations",
    "draft_comment_text", "confidence", "created_at",
    "extractor_versions_used"
  ],
  "properties": {
    "finding_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "submittal_id": { "type": "string", "format": "uuid" },
    "review_round": { "type": "integer", "minimum": 1 },
    "discipline": {
      "type": "string",
      "enum": ["plan_integrity", "architectural", "accessibility", "structural",
               "mechanical", "electrical", "plumbing", "energy",
               "fire_life_safety", "calgreen"]
    },
    "rule_id": { "type": ["string", "null"] },
    "rule_version": { "type": ["string", "null"] },
    "llm_reasoner_id": { "type": ["string", "null"] },
    "prompt_hash": { "type": ["string", "null"] },
    "severity": { "type": "string", "enum": ["revise", "provide", "clarify", "reference_only"] },
    "requires_licensed_review": { "type": "boolean" },
    "sheet_reference": {
      "type": "object",
      "required": ["sheet_id"],
      "properties": {
        "sheet_id": { "type": "string" },
        "detail": { "type": ["string", "null"] }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["entity_id", "bbox"],
            "properties": {
              "entity_id": { "type": "string", "format": "uuid" },
              "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
              "raster_crop_uri": { "type": ["string", "null"] }
            }
          },
          {
            "type": "object",
            "required": ["measurement_id", "value", "unit", "confidence"],
            "properties": {
              "measurement_id": { "type": "string", "format": "uuid" },
              "value": { "type": "number" },
              "unit": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "trace": { "type": "array" }
            }
          }
        ]
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "section", "jurisdiction", "effective_date", "frozen_text"],
        "properties": {
          "code": { "type": "string" },
          "section": { "type": "string" },
          "jurisdiction": { "type": "string" },
          "effective_date": { "type": "string", "format": "date" },
          "frozen_text": { "type": "string" },
          "retrieval_chain": { "type": "array" },
          "amendments_applied": { "type": "array" }
        }
      }
    },
    "draft_comment_text": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "extractor_versions_used": { "type": "array", "items": { "type": "string" } }
  }
}
