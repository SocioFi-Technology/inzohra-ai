{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://inzohra.ai/schemas/cross_doc_claim.schema.json",
  "title": "CrossDocClaim",
  "type": "object",
  "required": ["claim_id", "project_id", "claim_type", "resolved_value", "sources", "created_at"],
  "properties": {
    "claim_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "claim_type": {
      "type": "string",
      "enum": ["occupancy_class", "construction_type", "conditioned_area", "climate_zone",
               "sprinklered", "r_value_wall", "r_value_roof", "r_value_floor",
               "u_factor_window", "stories", "fire_hazard_zone", "flood_zone", "code_cycle"]
    },
    "resolved_value": {},
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "document_id", "value"],
        "properties": {
          "entity_id": { "type": "string", "format": "uuid" },
          "document_id": { "type": "string", "format": "uuid" },
          "value": {},
          "bbox": { "type": ["array", "null"] }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id_a", "entity_id_b", "delta"],
        "properties": {
          "entity_id_a": { "type": "string", "format": "uuid" },
          "entity_id_b": { "type": "string", "format": "uuid" },
          "delta": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
