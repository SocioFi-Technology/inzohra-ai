{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://inzohra.ai/schemas/jurisdictional-pack.schema.json",
  "title": "JurisdictionalPack",
  "type": "object",
  "required": ["pack_id", "jurisdiction", "version", "effective_date", "amendments"],
  "properties": {
    "pack_id": { "type": "string" },
    "jurisdiction": { "type": "string" },
    "version": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" },
    "superseded_by": { "type": ["string", "null"] },
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["base_section_id", "operation", "amendment_text", "effective_date"],
        "properties": {
          "base_section_id": { "type": "string" },
          "operation": { "type": "string", "enum": ["replace", "append", "override", "insert_before", "insert_after"] },
          "amendment_text": { "type": "string" },
          "effective_date": { "type": "string", "format": "date" },
          "superseded_by": { "type": ["string", "null"] }
        }
      }
    },
    "agency_policies": { "type": "array" },
    "submittal_checklists": { "type": "array" },
    "drafter_examples": { "type": "array" },
    "letter_template": { "type": "object" },
    "fee_schedule": { "type": "object" }
  }
}
