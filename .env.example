# Copy to .env and fill in. .env is gitignored.

# --- Postgres ---
DATABASE_URL=postgresql://inzohra:inzohra_dev@localhost:5432/inzohra

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=inzohra_dev
S3_SECRET_KEY=inzohra_dev_secret
S3_BUCKET_RAW=inzohra-raw
S3_BUCKET_RASTER=inzohra-raster
S3_BUCKET_CROPS=inzohra-crops
S3_BUCKET_OUTPUT=inzohra-output

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx  # embeddings only

# --- Model selection ---
MODEL_PRIMARY=claude-sonnet-4-5
MODEL_ESCALATION=claude-opus-4-5
MODEL_CLASSIFIER=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-large

# --- App ---
NEXTAUTH_SECRET=replace-with-openssl-rand-32
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=inzohra-ai
